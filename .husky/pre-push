#!/usr/bin/env sh
set -e

if command -v pnpm >/dev/null 2>&1; then
  pnpm run check-types
  pnpm run test:web && pnpm run test:api:light
elif command -v docker >/dev/null 2>&1 && [ -f "./dx" ]; then
  bash dx run check-types
  bash dx run test:web:dx && bash dx run test:api:light:dx
else
  echo "pre-push: neither pnpm nor Docker+dx is available."
  exit 1
fi
