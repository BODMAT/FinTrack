ignore-scripts=true
min-release-age=10080 # 10080 min = 7 days
block-exotic-subdeps=true
save-exact=true
engine-strict=true
registry=https://registry.npmjs.org/
auto-install-peers=true
strict-peer-dependencies=false
force-legacy-deploy=true # pnpm v10 changed deploy default to require inject-workspace-packages; legacy mode preserves v9 behaviour for TS monorepos where inject causes duplicate type errors
