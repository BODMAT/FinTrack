# ── Runtime ─────────────────────────────────────────────────
NODE_ENV="development"

# ── Telegram bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="123456789:your_telegram_bot_token"

# ── API ─────────────────────────────────────────────────────
# Targets local (non-Docker) runs. In Docker the host is injected by compose
# (API_URL → api, REDIS_URL → redis — see compose.dev.yaml / compose.yaml).
API_URL="http://localhost:8000/api"

# ── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
