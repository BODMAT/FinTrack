{
  "name": "fintrack",
  "version": "0.1.0",
  "description": "Personal finance tracking application.",
  "contributors": [
    {
      "name": "Makar Dzhehur"
    },
    {
      "name": "Bohdan Matula"
    }
  ],
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky || echo \"husky not installed, skipping\"",
    "setup": "turbo run build --filter=@fintrack/types",
    "dev": "npm run setup && turbo run dev",
    "dev:web": "turbo run dev --filter=fintrack-web",
    "dev:api": "turbo run dev --filter=fintrack-api",
    "dev:bot": "turbo run dev --filter=fintrack-bot",
    "test:api:prod": "npm run prod -w fintrack-api",
    "test:api:prod:dx": "bash dx shell api npm run prod",
    "api:prisma:generate": "npm run prisma:generate -w fintrack-api",
    "api:prisma:generate:dx": "bash dx shell api npm run prisma:generate",
    "api:prisma:migrate:dev": "npm run prisma:migrate:dev -w fintrack-api",
    "api:prisma:migrate:dev:dx": "bash dx shell api npm run prisma:migrate:dev",
    "api:prisma:migrate:deploy": "npm run prisma:migrate:deploy -w fintrack-api",
    "api:prisma:migrate:deploy:dx": "bash dx shell api npm run prisma:migrate:deploy",
    "api:prisma:studio": "npm run prisma:studio -w fintrack-api",
    "api:prisma:studio:dx": "bash dx shell api npm run prisma:studio",
    "api:prisma:seed": "npm run prisma:seed -w fintrack-api",
    "api:prisma:seed:dx": "bash dx shell api npm run prisma:seed",
    "build": "turbo run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "eslint --fix .",
    "lint": "eslint .",
    "fix": "npm run format && npm run lint:fix",
    "check": "npm run format:check && npm run lint",
    "tidy": "npm run fix && npm run check",
    "check-types": "turbo run check-types",
    "test:api": "npm run test -w fintrack-api",
    "test:api:dx": "bash dx shell api npm run test",
    "test:web": "npm run test -w fintrack-web",
    "test:web:dx": "bash dx shell web npm run test",
    "test": "npm run test:api && npm run test:web",
    "test:dx": "bash dx shell api npm run test && bash dx shell web npm run test",
    "dump": "bash scripts/codebase-dump.sh",
    "dump:api": "bash scripts/codebase-dump.sh -d apps/api",
    "dump:web": "bash scripts/codebase-dump.sh -d apps/web",
    "dump:bot": "bash scripts/codebase-dump.sh -d apps/bot",
    "dump:db": "bash scripts/db-dump.sh -e apps/api/.env",
    "dump:db:dx": "bash scripts/db-dump.sh -e apps/api/.env.docker",
    "restore:db": "bash scripts/db-restore.sh -e apps/api/.env",
    "restore:db:dx": "bash scripts/db-restore.sh -e apps/api/.env.docker",
    "restore:db:reset": "bash scripts/db-restore.sh -e apps/api/.env --reset",
    "restore:db:reset:dx": "bash scripts/db-restore.sh -e apps/api/.env.docker --reset",
    "clean:db": "bash scripts/db-restore.sh -e apps/api/.env --clean",
    "clean:db:dx": "bash scripts/db-restore.sh -e apps/api/.env.docker --clean",
    "db:setup": "npm run api:prisma:generate && npm run api:prisma:migrate:deploy && npm run api:prisma:seed",
    "db:setup:dx": "bash dx run api:prisma:generate:dx && bash dx run api:prisma:migrate:deploy:dx && bash dx run api:prisma:seed:dx",
    "db:reset": "npm run api:prisma:generate && npm run clean:db && npm run api:prisma:migrate:deploy && npm run api:prisma:seed",
    "db:reset:dx": "bash dx run api:prisma:generate:dx && bash dx run clean:db:dx && bash dx run api:prisma:migrate:deploy:dx && bash dx run api:prisma:seed:dx"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "next": "^16.2.3",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.52.0"
  },
  "overrides": {
    "@types/express": "4.17.21",
    "@types/express-serve-static-core": "4.19.0",
    "next": "^16.2.3",
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "*",
    "@rolldown/binding-linux-x64-musl": "*",
    "@rollup/rollup-linux-x64-gnu": "^4.57.1",
    "@tailwindcss/oxide-linux-x64-gnu": "*",
    "lightningcss-linux-x64-gnu": "*"
  }
}
